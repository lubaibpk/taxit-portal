# ─────────────────────────────────────────────────────────────
# TAXIT PORTAL — Environment Variables
# ─────────────────────────────────────────────────────────────
# Copy this file to .env.local for local dev
# Set these same keys in Vercel → Project → Settings → Environment Variables

# Supabase project URL (find in: Supabase Dashboard → Project Settings → API)
REACT_APP_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase anon/public key (find in: Supabase Dashboard → Project Settings → API)
REACT_APP_SUPABASE_KEY=your-anon-public-key-here

# Admin credentials (change these — they are checked client-side)
REACT_APP_ADMIN_USERNAME=admin
REACT_APP_ADMIN_PASSWORD=taxit2024
